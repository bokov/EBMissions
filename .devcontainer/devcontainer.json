{
  "name": "R Dev Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {},
      "extensions": [
        "Ikuyadeu.r",
        "REditorSupport.r-lsp",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "github.vscode-github-actions"
      ]
    }
  },
  "forwardPorts": [3838],
  "postCreateCommand": "R -e 'install.packages(c(\"shinyjs\", \"bslib\", \"cookies\", \"googlesheets4\", \"tidyverse\", \"rio\", \"ggplot2\", \"vctrs\", \"igraph\", \"svglite\", \"testthat\"), repos = \"https://cloud.r-project.org\")'"
}
